Table event.event {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  event_code varchar(60) [not null, unique]
  title varchar(255) [not null]
  event_type varchar(40) [not null]
  start_at timestamp with time zone [not null]
  end_at timestamp with time zone
  capacity integer
  status varchar(30) [not null]
}

Table event.registration {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  event_id uuid [not null]
  organization_id uuid [not null]
  person_id uuid
  status varchar(30) [not null]
  registered_at timestamp with time zone [not null]
}

Table notification.template {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  template_code varchar(80) [not null, unique]
  channel varchar(20) [not null]
  locale varchar(10) [not null]
  subject_template text
  body_template text [not null]
  status varchar(30) [not null]
  approved_by uuid
}

Table notification.notification {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  recipient_type varchar(30) [not null]
  recipient_ref varchar(320) [not null]
  channel varchar(20) [not null]
  template_code varchar(80) [not null]
  status varchar(30) [not null]
  scheduled_at timestamp with time zone [not null]
  correlation_id uuid [not null]
}

Table notification.delivery_attempt {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  notification_id uuid [not null]
  attempt_no integer [not null]
  provider_code varchar(60) [not null]
  status varchar(30) [not null]
  provider_message_id varchar(160)
  response_code varchar(60)
  attempted_at timestamp with time zone [not null]
}

Table integration.partner {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  partner_code varchar(60) [not null, unique]
  name varchar(255) [not null]
  partner_type varchar(40) [not null]
  status varchar(30) [not null]
}

Table integration.endpoint_configuration {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  partner_id uuid [not null]
  environment varchar(20) [not null]
  base_url varchar(500) [not null]
  auth_type varchar(40) [not null]
  secret_reference varchar(255) [not null]
  timeout_ms integer [not null]
  retry_policy jsonb [not null]
}

Table integration.outbox_event {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  aggregate_type varchar(80) [not null]
  aggregate_id uuid [not null]
  event_type varchar(120) [not null]
  payload jsonb [not null]
  status varchar(30) [not null]
  available_at timestamp with time zone [not null]
  published_at timestamp with time zone
}

Table integration.webhook_subscription {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  partner_id uuid [not null]
  event_type varchar(120) [not null]
  callback_url varchar(500) [not null]
  secret_reference varchar(255) [not null]
  active boolean [not null]
}

Table integration.webhook_delivery {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  subscription_id uuid [not null]
  outbox_event_id uuid [not null]
  attempt_no integer [not null]
  status varchar(30) [not null]
  http_status integer
  next_attempt_at timestamp with time zone
}

Table audit.audit_event {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  actor_user_id uuid
  actor_type varchar(30) [not null]
  action_code varchar(120) [not null]
  entity_type varchar(80) [not null]
  entity_id uuid
  before_hash char(64)
  after_hash char(64)
  correlation_id uuid [not null]
  ip_address inet
  metadata jsonb [not null]
}

Table audit.security_event {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  user_id uuid
  event_type varchar(120) [not null]
  severity varchar(20) [not null]
  source_ip inet
  details jsonb [not null]
  status varchar(30) [not null]
}

Table audit.data_export {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  requested_by uuid [not null]
  export_type varchar(80) [not null]
  scope jsonb [not null]
  record_count bigint
  document_id uuid
  expires_at timestamp with time zone
  approved_by uuid
}

Table reporting.report_definition {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  report_code varchar(80) [not null, unique]
  name varchar(255) [not null]
  report_type varchar(40) [not null]
  definition jsonb [not null]
  required_permission varchar(120) [not null]
  active boolean [not null]
}

Table reporting.report_execution {
  id uuid [pk, not null]
  created_at timestamp with time zone [not null]
  created_by uuid
  updated_at timestamp with time zone [not null]
  updated_by uuid
  version bigint [not null]
  report_definition_id uuid [not null]
  requested_by uuid [not null]
  parameters jsonb [not null]
  status varchar(30) [not null]
  started_at timestamp with time zone
  completed_at timestamp with time zone
  document_id uuid
}

