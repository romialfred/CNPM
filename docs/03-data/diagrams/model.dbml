Ref: recovery.recovery_case.membership_id > member.membership.id
Ref: recovery.recovery_case.fiscal_year_id > contribution.fiscal_year.id
Ref: recovery.recovery_action.recovery_case_id > recovery.recovery_case.id
Ref: recovery.promise_to_pay.recovery_case_id > recovery.recovery_case.id
Ref: incentive.bonus_line.calculation_id > incentive.bonus_calculation.id
Ref: incentive.bonus_line.payment_transaction_id > payment.payment_transaction.id
Ref: service.request.organization_id > member.organization.id
Ref: service.request_message.request_id > service.request.id
Ref: document.document_version.document_id > document.document.id
Ref: document.document_link.document_id > document.document.id
Ref: governance.meeting.commission_id > governance.commission.id
Ref: governance.meeting_attendance.meeting_id > governance.meeting.id
Ref: governance.meeting_attendance.person_id > member.person.id
