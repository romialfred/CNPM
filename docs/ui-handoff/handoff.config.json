{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "package": {
    "name": "CNPM UI/UX Handoff — Integrated Repository",
    "version": "1.0.0",
    "language": "fr",
    "status": "FINAL",
    "generatedAt": "2026-07-16"
  },
  "entrypoints": {
    "human": "START_HERE.md",
    "claudeCode": "../../CLAUDE.md",
    "codex": "../../AGENTS.md",
    "executiveGuideDocx": "guide/CNPM_UI_UX_Handoff_Guide_v1.0.docx",
    "executiveGuidePdf": "guide/CNPM_UI_UX_Handoff_Guide_v1.0.pdf"
  },
  "sourcePriority": [
    "docs/00-governance/source-of-truth.md",
    "product specifications, DCTD, API and RBAC source documents",
