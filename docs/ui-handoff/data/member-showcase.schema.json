{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CNPM Member Showcase",
  "type": "object",
  "required": [
    "slug",
    "name",
    "sector",
    "location",
    "verificationStatus",
    "publication"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "tagline": {
      "type": "string",
      "maxLength": 160
    },
    "sector": {
      "type": "string",
      "maxLength": 120
    },
    "location": {
      "type": "string",
      "maxLength": 160
    },
    "employeeRange": {
      "type": "string"
    },
    "foundedYear": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2100
    },
    "legalForm": {
      "type": "string"
    },
    "verificationStatus": {
      "enum": [
        "VERIFIED",
        "PENDING",
        "EXPIRED",
        "SUSPENDED",
        "UNVERIFIED"
      ]
    },
    "membershipStatus": {
      "enum": [
        "ACTIVE",
        "DORMANT",
        "SUSPENDED",
        "PROSPECT"
      ]
    },
    "summary": {
      "type": "string",
      "maxLength": 600
    },
    "contacts": {
      "type": "object"
    },
    "activities": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "maxLength": 120
      }
    },
    "projects": {
      "type": "array",
      "maxItems": 24,
      "items": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 120
          },
          "summary": {
            "type": "string",
            "maxLength": 300
          },
          "category": {
            "type": "string",
            "maxLength": 80
          },
          "imageAssetId": {
            "type": "string"
          }
        }
      }
    },
    "certifications": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "maxLength": 100
      }
    },
    "seo": {
      "type": "object"
    },
    "publication": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "DRAFT",
            "IN_REVIEW",
            "APPROVED",
            "SCHEDULED",
            "PUBLISHED",
            "REJECTED",
            "UNPUBLISHED"
          ]
        },
        "lastSavedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "scheduledAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  },
  "additionalProperties": true
}